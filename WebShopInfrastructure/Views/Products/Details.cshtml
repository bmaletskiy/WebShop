@model WebShopDomain.Model.Product

@{
    ViewData["Title"] = "Деталі товару";
}

<div class="container mt-4">

    <div class="row">

        <!-- Фото -->
        <div class="col-md-5">
            <div class="border rounded d-flex align-items-center justify-content-center"
                 style="height: 300px; background-color: #f8f9fa;">

                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid"
                         style="max-height: 300px; object-fit: contain;" />
                }
                else
                {
                    <span class="text-muted">Фото товару</span>
                }

            </div>
        </div>

        <!-- Інформація -->
        <div class="col-md-7">

            <h2>@Model.Name</h2>

            <p class="text-muted">
                @Model.Category?.Categoryname
            </p>

            <hr />

            <h4 class="text-success">
                @Model.Price ₴
            </h4>

            <p>
                <strong>В наявності:</strong> @Model.Availableqty
            </p>

            <p class="mt-3">
                @Model.Description
            </p>

            <div class="mt-4">

                @if (!User.IsInRole("admin") && !User.IsInRole("manager"))
                {
                    <form asp-controller="Carts" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />

                        <button type="submit" class="btn btn-primary btn-lg">
                            🛒 Додати в кошик
                        </button>
                    </form>
                }

                @if (User.IsInRole("admin"))
                {
                    <div class="mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            Delete
                        </a>
                    </div>
                }

            </div>

        </div>
    </div>

</div>