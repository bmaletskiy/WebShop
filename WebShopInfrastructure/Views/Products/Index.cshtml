@model IEnumerable<WebShopDomain.Model.Product>

@{
    ViewData["Title"] = "Товари за категорією";
}

<div class="container mt-4">

    <h3 class="mb-4">Товари: @ViewBag.CategoryName</h3>

    @if (User.IsInRole("admin"))
    {
        <div class="mb-3 d-flex gap-2 flex-wrap">

            <a asp-controller="Products" asp-action="Import"
                   class="btn btn-primary">
                Імпорт з Excel
            </a>

            <a asp-controller="Products" asp-action="Export"
                   class="btn btn-success">
                Експорт в Excel
            </a>

        </div>

        <div class="mb-3">
            <a asp-action="Create" asp-route-categoryId="@ViewBag.CategoryId"
                   class="btn btn-success">
                + Додати товар
            </a>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            У цій категорії ще немає товарів
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 shadow-sm border-0">

                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="card-img-top"
                                 style="height: 180px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center bg-light"
                                 style="height: 180px;">
                                <span class="text-muted small">Немає фото</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">
                                @item.Name
                            </h5>

                            <p class="card-text text-muted small">
                                @item.Description
                            </p>

                            <div class="mt-auto mb-2">
                                <span class="fs-5 fw-bold">
                                    @item.Price ₴
                                </span>
                            </div>

                            <div class="text-muted small mb-2">
                                В наявності: @item.Availableqty
                            </div>

                            <div class="d-grid gap-2">

                                <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-dark btn-sm">
                                    Деталі
                                </a>

                                @if (!User.IsInRole("manager") && !User.IsInRole("admin"))
                                {
                                    <form asp-controller="Carts" asp-action="AddToCart" method="post">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm">
                                            В кошик
                                        </button>
                                    </form>
                                }

                                @if (User.IsInRole("admin"))
                                {
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                               class="btn btn-warning btn-sm w-50">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-danger btn-sm w-50">
                                            Delete
                                        </a>
                                    </div>
                                }

                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>