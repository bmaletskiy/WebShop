@model WebShopDomain.Model.Category

@{
    ViewData["Title"] = "Delete";
}

<h1>Видалити категорію</h1>

<div>

    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Categoryname)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Categoryname)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Categoryinfo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Categoryinfo)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Видалити" class="btn btn-danger" /> |
        <a asp-action="Index">назад до списку</a>
    </form>
</div>
